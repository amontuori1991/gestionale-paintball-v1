@model Full_Metal_Paintball_Carmagnola.Models.PrenotazionePubblicaViewModel
@using System.Text.Json

@{
    Layout = null;
    ViewData["Title"] = "Richiesta prenotazione";
    var slotsJson = JsonSerializer.Serialize(Model.Giorni.SelectMany(g => g.Slot));
    var closedDatesJson = JsonSerializer.Serialize(Model.DateChiusure);
}

<!doctype html>
<html lang="it">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Richiesta prenotazione - Full Metal Paintball</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet" />
    <style>
        :root {
            --field: #25331f;
            --moss: #53643d;
            --sand: #efe6c8;
            --paper: rgba(255, 255, 255, .94);
            --line: rgba(37, 51, 31, .16);
            --accent: #d97706;
            --green: #2f7d46;
            --ink: #172114;
        }

        * {
            box-sizing: border-box;
        }

        body {
            background:
                radial-gradient(circle at top left, rgba(217, 119, 6, .24), transparent 28rem),
                radial-gradient(circle at bottom right, rgba(83, 100, 61, .28), transparent 26rem),
                linear-gradient(135deg, #dfe6c9, #f7f2df 48%, #c7d3b8);
            color: var(--ink);
            font-family: "Trebuchet MS", "Segoe UI", sans-serif;
            margin: 0;
            min-height: 100vh;
        }

        .public-shell {
            margin: 0 auto;
            max-width: 1100px;
            padding: 24px 14px 42px;
        }

        .hero {
            background: linear-gradient(135deg, rgba(37, 51, 31, .96), rgba(83, 100, 61, .9));
            border-radius: 28px;
            box-shadow: 0 24px 48px rgba(23, 33, 20, .2);
            color: #fff;
            overflow: hidden;
            padding: 28px;
            position: relative;
        }

        .hero::after {
            background: repeating-linear-gradient(135deg, rgba(255,255,255,.08) 0 8px, transparent 8px 18px);
            content: "";
            inset: 0;
            opacity: .4;
            position: absolute;
        }

        .hero-content {
            position: relative;
            z-index: 1;
        }

        .hero-kicker {
            color: #f7d78b;
            font-size: .88rem;
            font-weight: 900;
            letter-spacing: .12em;
            text-transform: uppercase;
        }

        h1 {
            font-size: clamp(2rem, 6vw, 4.2rem);
            line-height: .95;
            margin: 10px 0 14px;
            max-width: 820px;
        }

        .hero p {
            color: rgba(255,255,255,.86);
            font-size: 1.05rem;
            line-height: 1.5;
            margin: 0;
            max-width: 780px;
        }

        .notice {
            align-items: center;
            background: rgba(255,255,255,.12);
            border: 1px solid rgba(255,255,255,.2);
            border-radius: 18px;
            display: flex;
            gap: 10px;
            margin-top: 18px;
            padding: 12px 14px;
        }

        .booking-card {
            background: var(--paper);
            border: 1px solid var(--line);
            border-radius: 26px;
            box-shadow: 0 18px 42px rgba(23, 33, 20, .13);
            margin-top: 20px;
            padding: 22px;
        }

        .booking-card.is-hidden,
        .mode-fields.is-hidden,
        .slot-section.is-hidden {
            display: none;
        }

        .choice-grid {
            display: grid;
            gap: 16px;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            margin-top: 20px;
        }

        .choice-card {
            background: rgba(255, 255, 255, .92);
            border: 1px solid var(--line);
            border-radius: 24px;
            box-shadow: 0 16px 34px rgba(23, 33, 20, .11);
            color: var(--ink);
            cursor: pointer;
            padding: 22px;
            text-align: left;
            transition: transform .16s ease, box-shadow .16s ease, border-color .16s ease;
        }

        .choice-card:hover,
        .choice-card.active {
            border-color: rgba(47, 125, 70, .42);
            box-shadow: 0 20px 42px rgba(23, 33, 20, .16);
            transform: translateY(-2px);
        }

        .choice-icon {
            align-items: center;
            background: rgba(47, 125, 70, .12);
            border-radius: 16px;
            color: var(--green);
            display: inline-flex;
            font-size: 1.5rem;
            height: 46px;
            justify-content: center;
            margin-bottom: 14px;
            width: 46px;
        }

        .choice-card h2 {
            font-size: 1.35rem;
            margin: 0 0 8px;
        }

        .choice-card p {
            color: #5d6a54;
            line-height: 1.45;
            margin: 0;
        }

        .mode-alert {
            background: rgba(217, 119, 6, .12);
            border: 1px solid rgba(217, 119, 6, .2);
            border-radius: 16px;
            color: #854d0e;
            font-weight: 900;
            line-height: 1.45;
            margin-bottom: 16px;
            padding: 14px;
        }

        .form-grid {
            display: grid;
            gap: 14px;
            grid-template-columns: repeat(3, minmax(0, 1fr));
        }

        label {
            color: #32422b;
            display: grid;
            font-size: .9rem;
            font-weight: 900;
            gap: 7px;
        }

        input,
        select,
        textarea {
            background: #fff;
            border: 1px solid #c9d2bd;
            border-radius: 14px;
            color: #172114;
            font: inherit;
            padding: 12px 13px;
            width: 100%;
        }

        textarea {
            min-height: 86px;
            resize: vertical;
        }

        .full-span {
            grid-column: 1 / -1;
        }

        .slot-section {
            margin-top: 20px;
        }

        .slot-section h2 {
            font-size: 1.25rem;
            margin: 0 0 6px;
        }

        .slot-helper {
            color: #5d6a54;
            margin: 0 0 14px;
        }

        .slot-days {
            display: grid;
            gap: 14px;
        }

        .day-card {
            background: #fff;
            border: 1px solid rgba(83, 100, 61, .18);
            border-radius: 20px;
            overflow: hidden;
        }

        .day-title {
            align-items: center;
            background: linear-gradient(135deg, rgba(83, 100, 61, .14), rgba(239, 230, 200, .72));
            display: flex;
            justify-content: space-between;
            padding: 14px 16px;
        }

        .day-title strong {
            font-size: 1.05rem;
        }

        .slot-buttons {
            display: flex;
            flex-wrap: wrap;
            gap: 9px;
            padding: 14px 16px 16px;
        }

        .slot-btn {
            background: rgba(47, 125, 70, .1);
            border: 1px solid rgba(47, 125, 70, .22);
            border-radius: 999px;
            color: #17542a;
            cursor: pointer;
            font-weight: 900;
            padding: 10px 12px;
        }

        .slot-btn.active {
            background: var(--green);
            color: #fff;
        }

        .empty-slots {
            background: rgba(217, 119, 6, .12);
            border: 1px solid rgba(217, 119, 6, .2);
            border-radius: 16px;
            color: #854d0e;
            display: none;
            font-weight: 900;
            padding: 14px;
        }

        .selected-summary {
            background: rgba(37, 51, 31, .08);
            border-radius: 16px;
            color: #25331f;
            font-weight: 900;
            margin-top: 14px;
            padding: 13px 14px;
        }

        .actions {
            display: flex;
            gap: 12px;
            justify-content: flex-end;
            margin-top: 18px;
        }

        .whatsapp-btn {
            align-items: center;
            background: #18a64a;
            border: none;
            border-radius: 16px;
            color: #fff;
            cursor: pointer;
            display: inline-flex;
            font-weight: 950;
            gap: 9px;
            padding: 13px 18px;
        }

        .whatsapp-btn:disabled {
            cursor: not-allowed;
            opacity: .45;
        }

        .error-message {
            color: #b91c1c;
            display: none;
            font-weight: 900;
            margin-top: 12px;
        }

        .faq-card {
            background: rgba(255, 255, 255, .9);
            border: 1px solid var(--line);
            border-radius: 26px;
            box-shadow: 0 18px 42px rgba(23, 33, 20, .11);
            margin-top: 20px;
            padding: 22px;
        }

        .faq-card h2 {
            font-size: clamp(1.5rem, 4vw, 2.4rem);
            line-height: 1;
            margin: 0 0 8px;
        }

        .faq-intro {
            color: #5d6a54;
            margin: 0 0 16px;
        }

        .faq-list {
            display: grid;
            gap: 10px;
        }

        .faq-item {
            background: #fff;
            border: 1px solid rgba(83, 100, 61, .18);
            border-radius: 18px;
            overflow: hidden;
        }

        .faq-item summary {
            align-items: center;
            cursor: pointer;
            display: flex;
            font-weight: 950;
            gap: 10px;
            justify-content: space-between;
            list-style: none;
            padding: 15px 16px;
        }

        .faq-item summary::-webkit-details-marker {
            display: none;
        }

        .faq-item summary::after {
            color: var(--accent);
            content: "+";
            font-size: 1.4rem;
            line-height: 1;
        }

        .faq-item[open] summary::after {
            content: "−";
        }

        .faq-answer {
            border-top: 1px solid rgba(83, 100, 61, .14);
            color: #3d4b35;
            line-height: 1.55;
            padding: 0 16px 16px;
            white-space: pre-line;
        }

        @@media (max-width: 760px) {
            .public-shell {
                padding: 12px 10px 30px;
            }

            .hero,
            .booking-card,
            .faq-card {
                border-radius: 20px;
                padding: 18px;
            }

            .form-grid {
                grid-template-columns: 1fr;
            }

            .choice-grid {
                grid-template-columns: 1fr;
            }

            .actions {
                justify-content: stretch;
            }

            .whatsapp-btn {
                justify-content: center;
                width: 100%;
            }
        }
    </style>
</head>
<body>
    <main class="public-shell">
        <section class="hero">
            <div class="hero-content">
                <div class="hero-kicker">Full Metal Paintball Carmagnola</div>
                <h1>Richiedi la tua prenotazione</h1>
                <p>
                    Scegli se richiedere un turno nel weekend o in settimana, compila i dati principali e invia la richiesta su WhatsApp.
                    La prenotazione sarà confermata solo dopo risposta dello staff.
                </p>
            </div>
        </section>

        <section class="choice-grid" aria-label="Scegli il tipo di richiesta">
            <button type="button" class="choice-card" data-mode-button="weekend">
                <span class="choice-icon"><i class="bi bi-calendar-week"></i></span>
                <h2>Turni weekend</h2>
                <p>Consulta gli slot liberi di sabato e domenica e invia una richiesta già completa.</p>
            </button>
            <button type="button" class="choice-card" data-mode-button="weekday">
                <span class="choice-icon"><i class="bi bi-calendar-plus"></i></span>
                <h2>Turni infrasettimanali</h2>
                <p>Indica una data e un orario di interesse: lo staff verificherà disponibilità del campo e dello staff.</p>
            </button>
        </section>

        <section id="BookingCard" class="booking-card is-hidden">
            <form id="PublicBookingForm">
                <div id="WeekdayNotice" class="mode-alert is-hidden">
                    Per i turni infrasettimanali è necessario chiedere disponibilità allo staff. Puoi selezionare solo date con almeno 7 giorni di preavviso; la prenotazione sarà confermata solo dopo risposta.
                </div>
                <div class="form-grid">
                    <label>
                        Nome e cognome referente
                        <input type="text" id="CustomerName" required maxlength="80" placeholder="Mario Rossi" />
                    </label>
                    <label id="WeekendDateField" class="mode-fields">
                        Data di interesse
                        <select id="BookingDate" required>
                            <option value="">Seleziona una data</option>
                            @foreach (var giorno in Model.Giorni)
                            {
                                <option value="@giorno.Data.ToString("yyyy-MM-dd")">@giorno.GiornoLabel @giorno.DataLabel</option>
                            }
                        </select>
                    </label>
                    <label id="WeekdayDateField" class="mode-fields is-hidden">
                        Data di interesse
                        <input type="date" id="WeekdayDate" min="@Model.PrimaDataInfrasettimanale.ToString("yyyy-MM-dd")" />
                    </label>
                    <label id="WeekdayTimeField" class="mode-fields is-hidden">
                        Orario desiderato
                        <input type="time" id="WeekdayStartTime" min="09:00" step="1800" />
                    </label>
                    <label>
                        Numero partecipanti
                        <input type="number" id="Participants" required min="1" max="40" placeholder="Es. 10" />
                    </label>
                    <label>
                        Lingua richiesta
                        <select id="BookingLanguage" required>
                            <option value="ITA">ITA</option>
                            <option value="ENG">ENG</option>
                        </select>
                    </label>
                    <label>
                        Durata partita
                        <select id="Duration" required>
                            <option value="1">1 ora</option>
                            <option value="1.5">1 ora e mezza</option>
                            <option value="2">2 ore</option>
                        </select>
                    </label>
                    <label>
                        Tipo gruppo
                        <select id="GroupType" required>
                            <option value="Adulti">Adulti</option>
                            <option value="Kids">Kids</option>
                        </select>
                    </label>
                    <label>
                        Colpi
                        <select id="ShotsType" required>
                            <option value="Standard">Standard</option>
                            <option value="Illimitati">Illimitati</option>
                        </select>
                    </label>
                    <label>
                        Caccia al coniglio
                        <select id="RabbitHunt">
                            <option value="No">No</option>
                            <option value="Sì, 1 costume">Sì, 1 costume</option>
                            <option value="Sì, 2 costumi">Sì, 2 costumi</option>
                        </select>
                    </label>
                    <label class="full-span">
                        Note o richieste
                        <textarea id="Notes" maxlength="500" placeholder="Es. addio al celibato, compleanno, preferenze orarie..."></textarea>
                    </label>
                </div>

                <div id="WeekendSlotSection" class="slot-section">
                    <h2>Slot liberi disponibili</h2>
                    <p class="slot-helper">Seleziona una data di interesse: qui sotto compariranno solo gli orari disponibili per quel giorno.</p>
                    <div id="EmptySlots" class="empty-slots">Seleziona una data per visualizzare gli slot disponibili.</div>
                    <div id="SlotDays" class="slot-days"></div>
                    <div id="SelectedSummary" class="selected-summary">Seleziona uno slot libero per procedere.</div>
                </div>

                <div id="ErrorMessage" class="error-message"></div>
                <div class="actions">
                    <button id="WhatsappButton" class="whatsapp-btn" type="submit" disabled>
                        <i class="bi bi-whatsapp"></i>
                        Invia richiesta su WhatsApp
                    </button>
                </div>
            </form>
        </section>

        <section class="faq-card">
            <h2>Domande frequenti</h2>
            <p class="faq-intro">Qui trovi le informazioni principali su prenotazione, costi, modalità di gioco e regole del campo.</p>
            <div class="faq-list">
                @foreach (var item in Model.Faq)
                {
                    <details class="faq-item">
                        <summary>@item.Domanda</summary>
                        <div class="faq-answer">@item.Risposta</div>
                    </details>
                }
            </div>
        </section>
    </main>

    <script>
        (() => {
            const slots = @Html.Raw(slotsJson);
            const closedDates = new Set(@Html.Raw(closedDatesJson));
            const whatsappNumber = '393468741192';
            const modeButtons = Array.from(document.querySelectorAll('[data-mode-button]'));
            const bookingCard = document.getElementById('BookingCard');
            const weekendDateField = document.getElementById('WeekendDateField');
            const weekdayDateField = document.getElementById('WeekdayDateField');
            const weekdayTimeField = document.getElementById('WeekdayTimeField');
            const weekdayNotice = document.getElementById('WeekdayNotice');
            const weekendSlotSection = document.getElementById('WeekendSlotSection');
            const slotDays = document.getElementById('SlotDays');
            const emptySlots = document.getElementById('EmptySlots');
            const bookingDateInput = document.getElementById('BookingDate');
            const weekdayDateInput = document.getElementById('WeekdayDate');
            const weekdayStartTimeInput = document.getElementById('WeekdayStartTime');
            const durationInput = document.getElementById('Duration');
            const bookingLanguageInput = document.getElementById('BookingLanguage');
            const groupTypeInput = document.getElementById('GroupType');
            const shotsTypeInput = document.getElementById('ShotsType');
            const rabbitInput = document.getElementById('RabbitHunt');
            const selectedSummary = document.getElementById('SelectedSummary');
            const whatsappButton = document.getElementById('WhatsappButton');
            const form = document.getElementById('PublicBookingForm');
            const errorMessage = document.getElementById('ErrorMessage');
            let selectedSlot = null;
            let bookingMode = null;

            function timeToMinutes(value) {
                const [hours, minutes] = value.split(':').map(Number);
                return (hours * 60) + minutes;
            }

            function minutesToTime(minutes) {
                const hours = Math.floor(minutes / 60).toString().padStart(2, '0');
                const mins = (minutes % 60).toString().padStart(2, '0');
                return `${hours}:${mins}`;
            }

            function getCompatibleStarts(slot, durationHours) {
                const starts = [];
                const start = timeToMinutes(slot.Inizio);
                const end = timeToMinutes(slot.Fine);
                const durationMinutes = Math.round(durationHours * 60);
                for (let cursor = start; cursor + durationMinutes <= end; cursor += 30) {
                    starts.push({
                        data: slot.Data,
                        giorno: slot.Giorno,
                        inizio: minutesToTime(cursor),
                        fine: minutesToTime(cursor + durationMinutes),
                        durata: durationHours
                    });
                }
                return starts;
            }

            function updateGroupRules() {
                const isKids = groupTypeInput.value === 'Kids';
                if (isKids) {
                    shotsTypeInput.value = 'Illimitati';
                    shotsTypeInput.disabled = true;
                    rabbitInput.value = 'No';
                    rabbitInput.disabled = true;
                } else {
                    shotsTypeInput.disabled = false;
                    rabbitInput.disabled = false;
                }
            }

            function setBookingMode(mode) {
                bookingMode = mode;
                bookingCard.classList.remove('is-hidden');
                showError('');
                modeButtons.forEach(button => button.classList.toggle('active', button.dataset.modeButton === mode));

                const isWeekend = mode === 'weekend';
                weekendDateField.classList.toggle('is-hidden', !isWeekend);
                weekdayDateField.classList.toggle('is-hidden', isWeekend);
                weekdayTimeField.classList.toggle('is-hidden', isWeekend);
                weekdayNotice.classList.toggle('is-hidden', isWeekend);
                weekendSlotSection.classList.toggle('is-hidden', !isWeekend);

                bookingDateInput.required = isWeekend;
                weekdayDateInput.required = !isWeekend;
                weekdayStartTimeInput.required = !isWeekend;
                whatsappButton.disabled = isWeekend;

                if (isWeekend) {
                    renderSlots();
                } else {
                    selectedSlot = null;
                    selectedSummary.textContent = 'Compila data e orario di interesse per inviare la richiesta.';
                    slotDays.innerHTML = '';
                    emptySlots.style.display = 'none';
                    whatsappButton.disabled = false;
                }

                bookingCard.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }

            function selectSlot(slot, button) {
                selectedSlot = slot;
                document.querySelectorAll('.slot-btn.active').forEach(item => item.classList.remove('active'));
                button.classList.add('active');
                whatsappButton.disabled = false;
                selectedSummary.textContent = `Slot selezionato: ${slot.giorno}, dalle ${slot.inizio} alle ${slot.fine}`;
            }

            function renderSlots() {
                if (bookingMode !== 'weekend') {
                    return;
                }

                selectedSlot = null;
                whatsappButton.disabled = true;
                selectedSummary.textContent = 'Seleziona uno slot libero per procedere.';
                slotDays.innerHTML = '';
                const selectedDate = bookingDateInput.value;
                const duration = Number(durationInput.value);
                const grouped = new Map();

                if (!selectedDate) {
                    emptySlots.textContent = 'Seleziona una data per visualizzare gli slot disponibili.';
                    emptySlots.style.display = 'block';
                    return;
                }

                slots.forEach(slot => {
                    if (slot.Data !== selectedDate) return;

                    getCompatibleStarts(slot, duration).forEach(start => {
                        const key = `${start.data}|${start.giorno}`;
                        if (!grouped.has(key)) grouped.set(key, []);
                        grouped.get(key).push(start);
                    });
                });

                emptySlots.textContent = 'Al momento non ci sono slot compatibili con la durata selezionata per questa data.';
                emptySlots.style.display = grouped.size === 0 ? 'block' : 'none';

                grouped.forEach((daySlots, key) => {
                    const [, giorno] = key.split('|');
                    const card = document.createElement('article');
                    card.className = 'day-card';

                    const title = document.createElement('div');
                    title.className = 'day-title';
                    title.innerHTML = `<strong>${giorno}</strong><span>${daySlots.length} orari</span>`;
                    card.appendChild(title);

                    const buttons = document.createElement('div');
                    buttons.className = 'slot-buttons';
                    daySlots.forEach(slot => {
                        const button = document.createElement('button');
                        button.type = 'button';
                        button.className = 'slot-btn';
                        button.textContent = `${slot.inizio} - ${slot.fine}`;
                        button.addEventListener('click', () => selectSlot(slot, button));
                        buttons.appendChild(button);
                    });

                    card.appendChild(buttons);
                    slotDays.appendChild(card);
                });
            }

            function showError(text) {
                errorMessage.textContent = text;
                errorMessage.style.display = text ? 'block' : 'none';
            }

            function isWeekendDate(value) {
                const date = new Date(`${value}T00:00:00`);
                return date.getDay() === 0 || date.getDay() === 6;
            }

            function formatItalianDate(value) {
                const date = new Date(`${value}T00:00:00`);
                return date.toLocaleDateString('it-IT');
            }

            function buildWhatsappMessage() {
                const name = document.getElementById('CustomerName').value.trim();
                const participants = document.getElementById('Participants').value.trim();
                const notes = document.getElementById('Notes').value.trim();
                const isEnglish = bookingLanguageInput.value === 'ENG';
                const commonLines = [
                    `${isEnglish ? 'Contact person' : 'Referente'}: ${name}`,
                    `${isEnglish ? 'Duration' : 'Durata'}: ${durationInput.options[durationInput.selectedIndex].text}`,
                    `${isEnglish ? 'Expected participants' : 'Partecipanti indicativi'}: ${participants}`,
                    `${isEnglish ? 'Group type' : 'Tipo gruppo'}: ${groupTypeInput.value}`,
                    `${isEnglish ? 'Paintballs' : 'Colpi'}: ${shotsTypeInput.value}`,
                    `${isEnglish ? 'Rabbit hunt' : 'Caccia al coniglio'}: ${rabbitInput.value}`,
                    notes ? `${isEnglish ? 'Notes' : 'Note'}: ${notes}` : null
                ].filter(Boolean);

                if (bookingMode === 'weekday') {
                    if (isEnglish) {
                        return [
                            'Hi, I would like to request availability for a weekday paintball match.',
                            '',
                            commonLines[0],
                            `Preferred date: ${formatItalianDate(weekdayDateInput.value)}`,
                            `Preferred start time: ${weekdayStartTimeInput.value}`,
                            ...commonLines.slice(1),
                            '',
                            'I look forward to confirmation of field and staff availability.'
                        ].filter(Boolean).join('\n');
                    }

                    return [
                        'Salve, vorrei richiedere disponibilità per una partita di paintball infrasettimanale.',
                        '',
                        commonLines[0],
                        `Data di interesse: ${formatItalianDate(weekdayDateInput.value)}`,
                        `Orario desiderato: ${weekdayStartTimeInput.value}`,
                        ...commonLines.slice(1),
                        '',
                        'Resto in attesa di conferma disponibilità del campo e dello staff.'
                    ].filter(Boolean).join('\n');
                }

                if (isEnglish) {
                    return [
                        'Hi, I would like to request availability for a paintball match.',
                        '',
                        commonLines[0],
                        `Date: ${selectedSlot.giorno}`,
                        `Requested time: ${selectedSlot.inizio} - ${selectedSlot.fine}`,
                        ...commonLines.slice(1),
                        '',
                        'I look forward to confirmation from the staff.'
                    ].filter(Boolean).join('\n');
                }

                return [
                    'Salve, vorrei richiedere disponibilità per una partita di paintball.',
                    '',
                    commonLines[0],
                    `Data: ${selectedSlot.giorno}`,
                    `Orario richiesto: ${selectedSlot.inizio} - ${selectedSlot.fine}`,
                    ...commonLines.slice(1),
                    '',
                    'Resto in attesa di conferma disponibilità da parte dello staff.'
                ].filter(Boolean).join('\n');
            }

            modeButtons.forEach(button => {
                button.addEventListener('click', () => setBookingMode(button.dataset.modeButton));
            });
            bookingDateInput.addEventListener('change', renderSlots);
            durationInput.addEventListener('change', renderSlots);
            groupTypeInput.addEventListener('change', updateGroupRules);

            form.addEventListener('submit', (event) => {
                event.preventDefault();
                showError('');

                if (!bookingMode) {
                    showError('Seleziona prima il tipo di richiesta.');
                    return;
                }

                if (bookingMode === 'weekend' && !selectedSlot) {
                    showError('Seleziona uno slot libero prima di procedere.');
                    return;
                }

                if (bookingMode === 'weekday' && weekdayDateInput.value && isWeekendDate(weekdayDateInput.value)) {
                    showError('Per i turni infrasettimanali seleziona una data dal lunedì al venerdì.');
                    return;
                }

                if (bookingMode === 'weekday' && weekdayDateInput.value && closedDates.has(weekdayDateInput.value)) {
                    showError('Il campo risulta chiuso nella data selezionata.');
                    return;
                }

                if (!form.reportValidity()) {
                    return;
                }

                const message = encodeURIComponent(buildWhatsappMessage());
                window.open(`https://wa.me/${whatsappNumber}?text=${message}`, '_blank', 'noopener');
            });

            updateGroupRules();
        })();
    </script>
</body>
</html>
