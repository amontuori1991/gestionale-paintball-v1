@model List<Full_Metal_Paintball_Carmagnola.Models.RangeTessereAcsi>
@using Full_Metal_Paintball_Carmagnola.Models

@{
    ViewData["Title"] = "Gestione Tessere ACSI";
    var tessereAssegnate = new HashSet<string>(
        ViewBag.TessereAssegnate ?? new List<string>()
    );
    var disponibili = Model.Where(t => !tessereAssegnate.Contains(t.NumeroDa.ToString())).ToList();
    var assegnate = Model.Where(t => tessereAssegnate.Contains(t.NumeroDa.ToString())).ToList();
}
<link href="~/css/tessere-acsi-responsive.css" rel="stylesheet" />

<div class="content-container tessere-acsi-page">
    <h2 class="text-center">Gestione Tessere ACSI</h2>

    <form asp-action="AddRange" method="post" class="mb-4">
        <div class="row g-3 align-items-center justify-content-center">
            <div class="col-auto">
                <label for="NumeroIniziale" class="form-label">Da Numero</label>
                <input type="number" class="form-control" id="NumeroIniziale" name="NumeroIniziale" required />
            </div>
            <div class="col-auto">
                <label for="NumeroFinale" class="form-label">A Numero</label>
                <input type="number" class="form-control" id="NumeroFinale" name="NumeroFinale" required />
            </div>
            <div class="col-auto">
                <label for="DataValidita" class="form-label">Valida fino al</label>
                <input type="date" class="form-control" id="DataValidita" name="DataValidita" required />
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-primary mt-3">Aggiungi Range</button>
            </div>
        </div>
    </form>

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger" role="alert">
            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <div>@error.ErrorMessage</div>
            }
        </div>
    }

    <hr />

    <form method="get" class="mb-4">
        <div class="input-group d-flex justify-content-center">
            <input type="number" name="numeroTessera" class="form-control" placeholder="Filtra per numero tessera" value="@Context.Request.Query["numeroTessera"]" style="max-width: 250px;" />
            <button type="submit" class="btn btn-outline-secondary">Filtra</button>
            <a href="@Url.Action("Index")" class="btn btn-outline-danger">Reset</a>
        </div>
    </form>

    <section class="tessere-acsi-section tessere-acsi-section--available">
        <button class="tessere-acsi-section__header" type="button" data-bs-toggle="collapse" data-bs-target="#tessereDisponibili" aria-expanded="true" aria-controls="tessereDisponibili">
            <span class="tessere-acsi-title">Tessere disponibili</span>
            <span class="tessere-acsi-count">@disponibili.Count</span>
            <i class="bi bi-chevron-down tessere-acsi-chevron" aria-hidden="true"></i>
        </button>

        <div class="collapse show" id="tessereDisponibili">
            @if (disponibili.Any())
            {
                <div class="table-responsive">
                    <table class="table table-bordered tessere-acsi-table">
                        <thead>
                            <tr>
                                <th>Numero tessera</th>
                                <th>Valida fino al</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var tessera in disponibili)
                            {
                                <tr>
                                    <td data-label="Numero tessera">@tessera.NumeroDa</td>
                                    <td data-label="Valida fino al">@(tessera.DataValidita?.ToString("dd/MM/yyyy") ?? "-")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="tessere-acsi-empty">Nessuna tessera disponibile.</div>
            }
        </div>
    </section>

    <section class="tessere-acsi-section tessere-acsi-section--used">
        <button class="tessere-acsi-section__header collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#tessereUtilizzate" aria-expanded="false" aria-controls="tessereUtilizzate">
            <span class="tessere-acsi-title">Tessere utilizzate</span>
            <span class="tessere-acsi-count">@assegnate.Count</span>
            <i class="bi bi-chevron-down tessere-acsi-chevron" aria-hidden="true"></i>
        </button>

        <div class="collapse" id="tessereUtilizzate">
            @if (assegnate.Any())
            {
                <div class="table-responsive">
                    <table class="table table-bordered tessere-acsi-table">
                        <thead>
                            <tr>
                                <th>Numero tessera</th>
                                <th>Valida fino al</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var tessera in assegnate)
                            {
                                <tr>
                                    <td data-label="Numero tessera">@tessera.NumeroDa</td>
                                    <td data-label="Valida fino al">@(tessera.DataValidita?.ToString("dd/MM/yyyy") ?? "-")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="tessere-acsi-empty">Nessuna tessera utilizzata.</div>
            }
        </div>
    </section>
</div>
