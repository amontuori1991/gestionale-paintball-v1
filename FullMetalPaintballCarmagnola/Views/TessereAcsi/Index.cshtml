@model List<Full_Metal_Paintball_Carmagnola.Models.RangeTessereAcsi>
@using Full_Metal_Paintball_Carmagnola.Models

@{
    ViewData["Title"] = "Gestione Tessere ACSI";
    var tessereAssegnate = new HashSet<string>(
        ViewBag.TessereAssegnate ?? new List<string>()
    );
    var disponibili = Model.Where(t => !t.Assegnata && !tessereAssegnate.Contains(t.NumeroDa.ToString())).ToList();
    var assegnate = Model.Where(t => t.Assegnata || tessereAssegnate.Contains(t.NumeroDa.ToString())).ToList();
    var fabbisognoTessere = ViewBag.FabbisognoTessere is int fabbisogno ? fabbisogno : 0;
    var margineTessere = disponibili.Count - fabbisognoTessere;
    var fabbisognoStatusClass = margineTessere < 0 ? "is-critical" : margineTessere <= 10 ? "is-warning" : "is-ok";
    var fabbisognoStatusText = margineTessere < 0
        ? "Ordine necessario"
        : margineTessere <= 10
            ? "Scorta bassa"
            : "Scorta ok";
}
<link href="~/css/tessere-acsi-responsive.css" rel="stylesheet" />
<style>
    .acsi-stock-panel {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 14px;
        margin: 22px 0;
    }

    .acsi-stock-card {
        border: 1px solid rgba(0, 0, 0, .08);
        border-radius: 22px;
        background: linear-gradient(135deg, rgba(255, 255, 255, .94), rgba(250, 245, 230, .88));
        box-shadow: 0 18px 42px rgba(0, 0, 0, .08);
        padding: 18px;
    }

    .acsi-stock-card__label {
        color: #6d6a5c;
        font-size: .85rem;
        font-weight: 800;
        letter-spacing: .02em;
        text-transform: uppercase;
    }

    .acsi-stock-card__value {
        color: #11140f;
        font-size: clamp(1.8rem, 4vw, 2.5rem);
        font-weight: 950;
        line-height: 1;
        margin-top: 8px;
    }

    .acsi-stock-card__hint {
        color: #7d796a;
        font-size: .85rem;
        margin-top: 8px;
    }

    .acsi-stock-card--status.is-ok {
        border-color: rgba(124, 195, 35, .38);
        background: linear-gradient(135deg, rgba(237, 255, 205, .95), rgba(255, 255, 255, .9));
    }

    .acsi-stock-card--status.is-warning {
        border-color: rgba(255, 128, 24, .45);
        background: linear-gradient(135deg, rgba(255, 244, 210, .96), rgba(255, 255, 255, .9));
    }

    .acsi-stock-card--status.is-critical {
        border-color: rgba(227, 30, 120, .45);
        background: linear-gradient(135deg, rgba(255, 225, 236, .96), rgba(255, 255, 255, .9));
    }

    @@media (max-width: 860px) {
        .acsi-stock-panel {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @@media (max-width: 540px) {
        .acsi-stock-panel {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="content-container tessere-acsi-page">
    <h2 class="text-center">Gestione Tessere ACSI</h2>

    <section class="acsi-stock-panel" aria-label="Fabbisogno tessere ACSI">
        <div class="acsi-stock-card">
            <div class="acsi-stock-card__label">Tessere disponibili</div>
            <div class="acsi-stock-card__value">@disponibili.Count</div>
            <div class="acsi-stock-card__hint">Range validi e non ancora assegnati.</div>
        </div>
        <div class="acsi-stock-card">
            <div class="acsi-stock-card__label">Fabbisogno tessere</div>
            <div class="acsi-stock-card__value">@fabbisognoTessere</div>
            <div class="acsi-stock-card__hint">Nr. P. partite nel periodo meno tessere già assegnate.</div>
        </div>
        <div class="acsi-stock-card">
            <div class="acsi-stock-card__label">Margine</div>
            <div class="acsi-stock-card__value">@margineTessere</div>
            <div class="acsi-stock-card__hint">Disponibili meno fabbisogno stimato.</div>
        </div>
        <div class="acsi-stock-card acsi-stock-card--status @fabbisognoStatusClass">
            <div class="acsi-stock-card__label">Stato ordine</div>
            <div class="acsi-stock-card__value">@fabbisognoStatusText</div>
            <div class="acsi-stock-card__hint">Avviso sotto le 10 tessere di margine.</div>
        </div>
    </section>

    <form asp-action="AddRange" method="post" class="mb-4">
        <div class="row g-3 align-items-center justify-content-center">
            <div class="col-auto">
                <label for="NumeroIniziale" class="form-label">Da Numero</label>
                <input type="number" class="form-control" id="NumeroIniziale" name="NumeroIniziale" required />
            </div>
            <div class="col-auto">
                <label for="NumeroFinale" class="form-label">A Numero</label>
                <input type="number" class="form-control" id="NumeroFinale" name="NumeroFinale" />
                <div class="form-text">Usalo se conosci il numero finale.</div>
            </div>
            <div class="col-auto">
                <label for="QuantitaTessere" class="form-label">Oppure quantità</label>
                <input type="number" class="form-control" id="QuantitaTessere" name="QuantitaTessere" min="1" placeholder="es. 300" />
                <div class="form-text">Da + quantità. Es. da 1025357, quantità 300.</div>
            </div>
            <div class="col-auto">
                <label for="DataValidita" class="form-label">Valida fino al</label>
                <input type="date" class="form-control" id="DataValidita" name="DataValidita" required />
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-primary mt-3">Aggiungi Tessere</button>
            </div>
        </div>
    </form>

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger" role="alert">
            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <div>@error.ErrorMessage</div>
            }
        </div>
    }

    <hr />

    <form method="get" class="mb-4">
        <div class="input-group d-flex justify-content-center">
            <input type="number" name="numeroTessera" class="form-control" placeholder="Filtra per numero tessera" value="@Context.Request.Query["numeroTessera"]" style="max-width: 250px;" />
            <button type="submit" class="btn btn-outline-secondary">Filtra</button>
            <a href="@Url.Action("Index")" class="btn btn-outline-danger">Reset</a>
        </div>
    </form>

    <section class="tessere-acsi-section tessere-acsi-section--available">
        <button class="tessere-acsi-section__header" type="button" data-bs-toggle="collapse" data-bs-target="#tessereDisponibili" aria-expanded="true" aria-controls="tessereDisponibili">
            <span class="tessere-acsi-title">Tessere disponibili</span>
            <span class="tessere-acsi-count">@disponibili.Count</span>
            <i class="bi bi-chevron-down tessere-acsi-chevron" aria-hidden="true"></i>
        </button>

        <div class="collapse show" id="tessereDisponibili">
            @if (disponibili.Any())
            {
                <div class="table-responsive">
                    <table class="table table-bordered tessere-acsi-table">
                        <thead>
                            <tr>
                                <th>Numero tessera</th>
                                <th>Valida fino al</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var tessera in disponibili)
                            {
                                <tr>
                                    <td data-label="Numero tessera">@tessera.NumeroDa</td>
                                    <td data-label="Valida fino al">@(tessera.DataValidita?.ToString("dd/MM/yyyy") ?? "-")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="tessere-acsi-empty">Nessuna tessera disponibile.</div>
            }
        </div>
    </section>

    <section class="tessere-acsi-section tessere-acsi-section--used">
        <button class="tessere-acsi-section__header collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#tessereUtilizzate" aria-expanded="false" aria-controls="tessereUtilizzate">
            <span class="tessere-acsi-title">Tessere utilizzate</span>
            <span class="tessere-acsi-count">@assegnate.Count</span>
            <i class="bi bi-chevron-down tessere-acsi-chevron" aria-hidden="true"></i>
        </button>

        <div class="collapse" id="tessereUtilizzate">
            @if (assegnate.Any())
            {
                <div class="table-responsive">
                    <table class="table table-bordered tessere-acsi-table">
                        <thead>
                            <tr>
                                <th>Numero tessera</th>
                                <th>Valida fino al</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var tessera in assegnate)
                            {
                                <tr>
                                    <td data-label="Numero tessera">@tessera.NumeroDa</td>
                                    <td data-label="Valida fino al">@(tessera.DataValidita?.ToString("dd/MM/yyyy") ?? "-")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="tessere-acsi-empty">Nessuna tessera utilizzata.</div>
            }
        </div>
    </section>
</div>
