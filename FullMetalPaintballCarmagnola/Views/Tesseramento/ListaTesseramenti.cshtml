@model IEnumerable<Full_Metal_Paintball_Carmagnola.Models.TesseramentoViewModel>

@{
    ViewData["Title"] = "Elenco Tesseramenti";
    Layout = "_Layout";
}
<link href="~/css/tesseramenti-responsive.css" rel="stylesheet" />

<div class="tess-page">


    <div class="tess-header">
        <div class="tess-header__icon">
            <i class="bi bi-person-badge"></i>
        </div>
        <div>
            <h2 class="tess-header__title">Elenco Tesseramenti</h2>
            <p class="tess-header__sub">Full Metal Paintball Carmagnola</p>
        </div>
    </div>


    <div class="tess-card">
        <div class="tess-card__body">
            <form method="get" asp-action="ListaTesseramenti">
                <div class="tess-filters__grid">

                    <div class="tess-filters__field">
                        <label class="tess-filters__label">ID Partita</label>
                        <input type="number" name="partitaId" value="@ViewBag.PartitaId"
                               placeholder="es. 42" class="tess-filters__input" style="width:110px;" />
                    </div>

                    <div class="tess-filters__field">
                        <label class="tess-filters__label">Nome</label>
                        <input type="text" name="searchNome" value="@ViewBag.SearchNome"
                               placeholder="Nome…" class="tess-filters__input" style="width:130px;" />
                    </div>

                    <div class="tess-filters__field">
                        <label class="tess-filters__label">Cognome</label>
                        <input type="text" name="searchCognome" value="@ViewBag.SearchCognome"
                               placeholder="Cognome…" class="tess-filters__input" style="width:130px;" />
                    </div>

                    <div class="tess-filters__field">
                        <label class="tess-filters__label">Data partita dal</label>
                        <input type="date" name="dataDa" value="@ViewBag.DataDa" class="tess-filters__input" style="width:150px;" />
                    </div>

                    <div class="tess-filters__field">
                        <label class="tess-filters__label">Data partita al</label>
                        <input type="date" name="dataA" value="@ViewBag.DataA" class="tess-filters__input" style="width:150px;" />
                    </div>

                    <div class="tess-filters__actions">
                        <button type="submit" class="btn-tess btn-tess--primary">
                            <i class="bi bi-funnel-fill"></i> Filtra
                        </button>
                        <a href="@Url.Action("ListaTesseramenti")" class="btn-tess btn-tess--secondary">
                            <i class="bi bi-x-lg"></i> Reset
                        </a>
                    </div>

                </div>
            </form>
        </div>
    </div>


    <div class="tess-card">

        <form method="post">
            @Html.AntiForgeryToken()


            <div class="tess-toolbar">
                <span class="tess-toolbar__label"><i class="bi bi-lightning-charge-fill me-1"></i>Azioni sui selezionati</span>

                <span class="selected-counter" id="selectedCounter">
                    <i class="bi bi-check-circle-fill"></i>
                    <span id="selectedCount">0</span> selezionati
                </span>

                <button type="submit" class="btn-tess btn-tess--success"
                        formaction="@Url.Action("ExportExcel")">
                    <i class="bi bi-file-earmark-excel-fill"></i> Esporta Excel
                </button>

                <button type="submit" class="btn-tess btn-tess--info"
                        formaction="@Url.Action("AssegnaTessere")">
                    <i class="bi bi-card-checklist"></i> Assegna Tessere
                </button>

                <button type="submit" class="btn-tess btn-tess--danger"
                        formaction="@Url.Action("DissociaTessereSelezionate")">
                    <i class="bi bi-scissors"></i> Dissocia Tessere
                </button>
            </div>


            @if (Model != null && Model.Any())
            {
                var sortedModel = Model
                    .OrderByDescending(t => t.DataPartita)
                    .ThenByDescending(t => t.PartitaId);

                <div class="tess-mobile-list">
                    @foreach (var t in sortedModel)
                    {
                        var scadenza = new DateTime(t.DataCreazione.Year, 12, 31);
                        var hasTessera = !string.IsNullOrEmpty(t.Tessera);

                        <article class="tess-mobile-card">
                            <div class="tess-mobile-card__top">
                                <label class="tess-mobile-card__select">
                                    <span>Seleziona</span>
                                    <input type="checkbox" name="tesseratiIds" value="@t.Id"
                                           class="tess-check select-item tess-mobile-check" />
                                </label>
                            </div>

                            <div class="tess-mobile-card__name">
                                <span>@t.Nome</span>
                                <strong>@t.Cognome</strong>
                            </div>

                            <div class="tess-mobile-card__row">
                                <span>Data partita</span>
                                <strong>@(t.DataPartita?.ToString("dd/MM/yyyy") ?? "Non indicata")</strong>
                            </div>

                            <div class="tess-mobile-card__row">
                                <span>Tessera</span>
                                @if (hasTessera)
                                {
                                    <strong class="badge-tessera badge-tessera--active">
                                        <i class="bi bi-check-circle-fill"></i> @t.Tessera
                                    </strong>
                                }
                                else
                                {
                                    <strong class="badge-tessera badge-tessera--none">
                                        <i class="bi bi-dash-circle"></i> Nessuna
                                    </strong>
                                }
                            </div>

                            <div class="tess-mobile-card__row">
                                <span>Azione</span>
                                @if (hasTessera)
                                {
                                    <button type="button" class="btn-tess btn-tess--ghost"
                                            onclick="dissociaTessera(@t.Id)">
                                        <i class="bi bi-scissors"></i> Dissocia
                                    </button>
                                }
                                else
                                {
                                    <strong class="tess-mobile-card__empty">Nessuna azione</strong>
                                }
                            </div>

                            <div class="tess-mobile-card__row">
                                <span>Scadenza</span>
                                <strong>@scadenza.ToShortDateString()</strong>
                            </div>
                        </article>
                    }
                </div>

                <div class="tess-table-wrap">
                    <table class="tess-table">
                        <thead>
                            <tr>
                                <th style="width:36px;">
                                    <input type="checkbox" id="selectAll" class="tess-check" />
                                </th>
                                <th>Partita ID</th>
                                <th>Data Partita</th>
                                <th>Nome</th>
                                <th>Cognome</th>
                                <th>Data Nascita</th>
                                <th>Genere</th>
                                <th>Comune Nascita</th>
                                <th>Comune Residenza</th>
                                <th>Email</th>
                                <th>Cellulare</th>
                                <th>Codice Fiscale</th>
                                <th>Tessera</th>
                                <th>Azione</th>
                                <th>Minorenne</th>
                                <th>Nome Genitore</th>
                                <th>Cognome Genitore</th>
                                <th>Creazione</th>
                                <th>Scadenza</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var t in sortedModel)
                            {
                                var scadenza = new DateTime(t.DataCreazione.Year, 12, 31);
                                var hasTessera = !string.IsNullOrEmpty(t.Tessera);

                                <tr>
                                    <td data-label="Sel.">
                                        <input type="checkbox" name="tesseratiIds" value="@t.Id"
                                               class="tess-check select-item" />
                                    </td>

                                    <td data-label="Partita ID">
                                        <span class="partita-pill">@t.PartitaId</span>
                                    </td>

                                    <td data-label="Data Partita">
                                        @t.DataPartita?.ToString("dd/MM/yyyy")
                                    </td>

                                    <td data-label="Nome">@t.Nome</td>
                                    <td data-label="Cognome"><strong>@t.Cognome</strong></td>

                                    <td data-label="Data Nascita">
                                        @(t.DataNascita?.ToString("dd/MM/yyyy") ?? "—")
                                    </td>

                                    <td data-label="Genere">@t.Genere</td>
                                    <td data-label="Comune Nascita">@t.ComuneNascita</td>
                                    <td data-label="Comune Residenza">@t.ComuneResidenza</td>
                                    <td data-label="Email">
                                        <a href="mailto:@t.Email" style="color:var(--fmp-blue);text-decoration:none;font-size:.78rem;">@t.Email</a>
                                    </td>
                                    <td data-label="Cellulare">@t.Cellulare</td>
                                    <td data-label="Codice Fiscale">
                                        <span style="font-family:monospace;font-size:.78rem;letter-spacing:.03em;">@t.CodiceFiscale</span>
                                    </td>

                                    <td data-label="Tessera">
                                        @if (hasTessera)
                                        {
                                            <span class="badge-tessera badge-tessera--active">
                                                <i class="bi bi-check-circle-fill"></i> @t.Tessera
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge-tessera badge-tessera--none">
                                                <i class="bi bi-dash-circle"></i> Nessuna
                                            </span>
                                        }
                                    </td>

                                    <td data-label="Azione">
                                        @if (hasTessera)
                                        {
                                            <button type="button" class="btn-tess btn-tess--ghost"
                                                    onclick="dissociaTessera(@t.Id)">
                                                <i class="bi bi-scissors"></i> Dissocia
                                            </button>
                                        }
                                        else
                                        {
                                            <span style="color:var(--fmp-muted);font-size:.78rem;">—</span>
                                        }
                                    </td>

                                    <td data-label="Minorenne">
                                        @if (t.Minorenne?.ToString().ToLower() == "si" ||
                                                                        t.Minorenne?.ToString().ToLower() == "sì" ||
                                                                        t.Minorenne?.ToString() == "true")
                                        {
                                            <span class="badge-minorenne--si"><i class="bi bi-person-fill-exclamation"></i> Sì</span>
                                        }
                                        else
                                        {
                                            <span class="badge-minorenne--no">No</span>
                                        }
                                    </td>

                                    <td data-label="Nome Genitore">@t.NomeGenitore</td>
                                    <td data-label="Cognome Genitore">@t.CognomeGenitore</td>

                                    <td data-label="Creazione">
                                        @t.DataCreazione.ToShortDateString()
                                    </td>

                                    <td data-label="Scadenza">
                                        @scadenza.ToShortDateString()
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="tess-empty">
                    <div class="tess-empty__icon"><i class="bi bi-inbox"></i></div>
                    <p class="tess-empty__text">Nessun tesseramento trovato</p>
                    <p style="font-size:.85rem;color:var(--fmp-muted);margin-top:6px;">
                        Prova a modificare i filtri o crea un nuovo tesseramento.
                    </p>
                </div>
            }

        </form>
    </div>


    <div class="tess-footer-nav">
        <a href="@Url.Action("Index", "Tesseramento")" class="btn-tess btn-tess--primary">
            <i class="bi bi-plus-circle-fill"></i> Nuovo Tesseramento
        </a>
        <a href="@Url.Action("Index", "Home")" class="btn-tess btn-tess--secondary">
            <i class="bi bi-house-fill"></i> Torna alla Home
        </a>
    </div>

</div>

<div class="modal fade tess-modal" id="confirmModal" tabindex="-1" aria-labelledby="confirmModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="confirmModalLabel">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>Conferma dissociazione
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Chiudi"></button>
            </div>
            <div class="modal-body">
                <p>Sei sicuro di voler <strong>dissociare la tessera</strong> da questo tesserato?</p>
                <p style="font-size:.85rem;color:var(--fmp-muted);">Questa operazione non può essere annullata automaticamente.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-tess btn-tess--secondary" data-bs-dismiss="modal">
                    <i class="bi bi-x-lg"></i> Annulla
                </button>
                <button type="button" id="confirmBtn" class="btn-tess btn-tess--danger">
                    <i class="bi bi-scissors"></i> Dissocia
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Select all / deselect + counter
        const selectAllEl   = document.getElementById('selectAll');
        const counterEl     = document.getElementById('selectedCounter');
        const countSpan     = document.getElementById('selectedCount');
        const items         = () => Array.from(document.querySelectorAll('.select-item')).filter(cb => cb.offsetParent !== null);

        function updateCounter() {
            const n = items().filter(cb => cb.checked).length;
            countSpan.textContent = n;
            if (n > 0) { counterEl.classList.add('visible'); }
            else        { counterEl.classList.remove('visible'); }
        }

        if (selectAllEl) {
            selectAllEl.addEventListener('change', function () {
                items().forEach(cb => cb.checked = this.checked);
                updateCounter();
            });
        }

        document.addEventListener('change', e => {
            if (e.target.classList.contains('select-item')) updateCounter();
        });

        // Dissocia singola
        let tesseraDaDissociare = null;
        const confirmModal = new bootstrap.Modal(document.getElementById('confirmModal'));

        function dissociaTessera(id) {
            tesseraDaDissociare = id;
            confirmModal.show();
        }

        document.getElementById('confirmBtn').addEventListener('click', async () => {
            if (!tesseraDaDissociare) return;

            const token = document.querySelector('form[method="post"] input[name="__RequestVerificationToken"]').value;

            try {
                const response = await fetch('@Url.Action("DissociaTessera", "Tesseramento")', {
                    method: 'POST',
                    headers: {
                        'RequestVerificationToken': token,
                        'Content-Type': 'application/x-www-form-urlencoded'
                    },
                    body: `tesseratoId=${tesseraDaDissociare}`
                });

                const data = await response.json();

                if (data.success) {
                    confirmModal.hide();
                    location.reload();
                } else {
                    alert(data.message || 'Errore nella dissociazione tessera.');
                }
            } catch (error) {
                console.error('Errore fetch:', error);
                alert('Errore di connessione durante la dissociazione della tessera.');
            }
        });
    </script>
}
