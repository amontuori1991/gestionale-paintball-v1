@model Full_Metal_Paintball_Carmagnola.Models.PricingCatalog
@using Full_Metal_Paintball_Carmagnola.Models

@{
    ViewData["Title"] = "Gestione Listini";
}

<style>
    .pricing-manage-table td,
    .pricing-manage-table th {
        vertical-align: top;
    }

    @@media (max-width: 768px) {
        .pricing-manage-table thead {
            display: none;
        }

        .pricing-manage-table,
        .pricing-manage-table tbody,
        .pricing-manage-table tr,
        .pricing-manage-table td {
            display: block;
            width: 100%;
        }

        .pricing-manage-table tr {
            border: 1px solid #e7dfc7;
            border-radius: 18px;
            background: #fffdf6;
            padding: 14px;
            margin-bottom: 14px;
            box-shadow: 0 8px 18px rgba(40, 30, 10, 0.06);
        }

        .pricing-manage-table td {
            border: 0;
            padding: 10px 0;
        }

        .pricing-manage-table td::before {
            content: attr(data-label);
            display: block;
            font-size: 0.82rem;
            font-weight: 700;
            color: #6f6345;
            margin-bottom: 6px;
            text-transform: uppercase;
            letter-spacing: 0.04em;
        }
    }
</style>

<div class="content-container">
    <div class="list-container mb-3">
        <div class="d-flex flex-wrap justify-content-between align-items-center gap-3">
            <div>
                <h2 class="mb-1">Gestione listini</h2>
                <p class="text-muted mb-0">Qui aggiorni sia le tabelle prezzi sia i testi generati nelle prenotazioni.</p>
            </div>
            <a class="btn btn-outline-secondary" href="@Url.Action("Index", "Prezzi")">Torna ai prezzi</a>
        </div>
    </div>

    @if (TempData["PricingSaved"] is string savedMessage)
    {
        <div class="alert alert-success">@savedMessage</div>
    }

    <form asp-action="Manage" method="post">
        @Html.AntiForgeryToken()

        <div class="list-container">
            <h3 class="mb-3">Listini</h3>
            <p class="text-muted">Il listino usato di default nelle nuove partite resta il secondo, cioe' il listino attuale.</p>
            <div class="row g-3">
                @for (var i = 0; i < Model.Listini.Count; i++)
                {
                    <input asp-for="Listini[i].Id" type="hidden" />
                    <div class="col-md-6">
                        <label asp-for="Listini[i].Name" class="form-label">
                            @(Model.Listini[i].Id == 1 ? "Nome listino precedente" : "Nome listino attuale")
                        </label>
                        <input asp-for="Listini[i].Name" class="form-control" />
                    </div>
                }
            </div>
            <div class="mt-3">
                <label asp-for="KidsPricingNote" class="form-label">Nota listino kids</label>
                <input asp-for="KidsPricingNote" class="form-control" />
            </div>
        </div>

        @foreach (var priceSection in new[]
        {
            new { Key = PricingSections.AdultsStandard, Title = "Partite Adulti" },
            new { Key = PricingSections.AdultsTournament, Title = "Tornei Adulti" },
            new { Key = PricingSections.Kids, Title = "Partite Kids" },
            new { Key = PricingSections.KidsTournament, Title = "Torneo Kids" },
            new { Key = PricingSections.RabbitHunt, Title = "Caccia al Coniglio" },
            new { Key = PricingSections.ExtraReloads, Title = "Ricariche Extra" }
        })
        {
            var rows = Model.Entries
                .Select((entry, index) => new { entry, index })
                .Where(x => x.entry.Section == priceSection.Key)
                .OrderBy(x => x.entry.SortOrder)
                .ToList();

            if (rows.Count == 0)
            {
                continue;
            }

            <div class="list-container">
                <h3 class="mb-3">@priceSection.Title</h3>
                <div class="table-responsive">
                    <table class="table align-middle pricing-manage-table">
                        <thead>
                            <tr>
                                <th>Voce</th>
                                <th>Colpi / Nota</th>
                                <th>@Model.GetLegacyListino().Name</th>
                                <th>@Model.GetCurrentListino().Name</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in rows)
                            {
                                <tr>
                                    <td data-label="Voce">
                                        <input asp-for="Entries[row.index].Code" type="hidden" />
                                        <input asp-for="Entries[row.index].Section" type="hidden" />
                                        <input asp-for="Entries[row.index].DurationHours" type="hidden" />
                                        <input asp-for="Entries[row.index].SortOrder" type="hidden" />
                                        <input asp-for="Entries[row.index].Label" class="form-control" />
                                        @if (!string.IsNullOrWhiteSpace(row.entry.Notes))
                                        {
                                            <div class="small text-muted mt-1">@row.entry.Notes</div>
                                        }
                                    </td>
                                    <td data-label="Colpi / Nota">
                                        <input asp-for="Entries[row.index].IncludedShots" class="form-control" />
                                    </td>
                                    <td data-label="@Model.GetLegacyListino().Name">
                                        <input asp-for="Entries[row.index].Listino1Price" class="form-control" inputmode="decimal" />
                                    </td>
                                    <td data-label="@Model.GetCurrentListino().Name">
                                        <input asp-for="Entries[row.index].Listino2Price" class="form-control" inputmode="decimal" />
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

        <div class="d-flex justify-content-end mb-4">
            <button type="submit" class="btn btn-primary">Salva listini</button>
        </div>
    </form>
</div>
