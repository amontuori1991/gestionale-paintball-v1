@model Full_Metal_Paintball_Carmagnola.Models.Tesseramento

@{
    Layout = null;
}

<!doctype html>
<html lang="it">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Disiscrizione confermata</title>
    <style>
        body {
            align-items: center;
            background: radial-gradient(circle at bottom right, rgba(166, 212, 42, .22), transparent 34%), #fffaf1;
            color: #151711;
            display: flex;
            font-family: Arial, Helvetica, sans-serif;
            justify-content: center;
            margin: 0;
            min-height: 100vh;
            padding: 24px;
        }

        .card {
            background: white;
            border: 1px solid rgba(0, 0, 0, .08);
            border-radius: 28px;
            box-shadow: 0 24px 58px rgba(0, 0, 0, .12);
            max-width: 560px;
            padding: 32px;
            text-align: center;
        }

        img {
            border-radius: 999px;
            height: 86px;
            object-fit: contain;
            width: 86px;
        }

        h1 {
            font-size: clamp(1.8rem, 6vw, 2.6rem);
            margin: 18px 0 10px;
        }

        p {
            color: #5e5a4d;
            font-size: 1.05rem;
            line-height: 1.55;
        }
    </style>
</head>
<body>
    <main class="card">
        <img src="https://i.imgur.com/K9Ugseg.gif" alt="Full Metal Paintball Carmagnola" />
        <h1>Disiscrizione confermata</h1>
        <p>L'indirizzo <strong>@Model.Email</strong> è stato rimosso dalle comunicazioni newsletter.</p>
        <p>Grazie, preferenza aggiornata correttamente.</p>
    </main>
</body>
</html>
