@using System.Globalization
@using Full_Metal_Paintball_Carmagnola.Models
@model IEnumerable<Full_Metal_Paintball_Carmagnola.Models.Partita>

@{
    var staffDefault = ViewBag.StaffList as List<string> ?? new List<string>();
    var staffDisponibiliPerData = ViewBag.StaffDisponibiliPerData as Dictionary<DateTime, List<string>>;
    var listinoLabels = ViewBag.ListinoLabels as IDictionary<short, string> ?? new Dictionary<short, string>();
    var pricingCatalog = ViewBag.PricingCatalog as PricingCatalog ?? new PricingCatalog();
    var weatherByPartitaId = ViewBag.WeatherByPartitaId as IReadOnlyDictionary<int, Full_Metal_Paintball_Carmagnola.Models.PartitaWeatherViewModel>
        ?? new Dictionary<int, Full_Metal_Paintball_Carmagnola.Models.PartitaWeatherViewModel>();
    short currentListinoId = ViewBag.CurrentListinoId is short currentValue ? currentValue : (short)2;
    const decimal MembershipFee = 5m;
    const int MinimumBillablePlayers = 8;

    var it = CultureInfo.GetCultureInfo("it-IT");

    string GetListinoLabel(short id) =>
        listinoLabels.TryGetValue(id, out var label) ? label : $"Listino {id}";

    string Money(decimal amount) => $"{amount.ToString("0.00", it)}€";

    string ReferenteLabel(Partita partita) =>
        !string.IsNullOrWhiteSpace(partita.NomeRiferimento)
            ? partita.NomeRiferimento.Trim()
            : partita.Riferimento?.Trim() ?? string.Empty;

    string TipoLabel(Partita partita) =>
        (partita.Tipo?.Equals("kids", StringComparison.OrdinalIgnoreCase) ?? false)
            ? "KIDS"
            : (string.IsNullOrWhiteSpace(partita.Tipo) ? "ADULTI" : partita.Tipo.ToUpperInvariant());

    string RiferimentoDettaglio(Partita partita)
    {
        var parts = new List<string>();
        var referente = ReferenteLabel(partita);
        if (!string.IsNullOrWhiteSpace(referente))
            parts.Add(referente);

        if (!string.IsNullOrWhiteSpace(partita.PrefissoTelefonoRiferimento) || !string.IsNullOrWhiteSpace(partita.TelefonoRiferimento))
            parts.Add($"{partita.PrefissoTelefonoRiferimento} {partita.TelefonoRiferimento}".Trim());

        return parts.Count > 0 ? string.Join(" - ", parts) : "Nessun riferimento indicato";
    }

    string? WhatsappUrl(Partita partita)
    {
        var prefix = new string((partita.PrefissoTelefonoRiferimento ?? string.Empty).Where(char.IsDigit).ToArray());
        var number = new string((partita.TelefonoRiferimento ?? string.Empty).Where(char.IsDigit).ToArray());
        if (string.IsNullOrWhiteSpace(prefix) || string.IsNullOrWhiteSpace(number))
            return null;

        return $"https://wa.me/{prefix}{number}";
    }

    string? WhatsappNumber(Partita partita)
    {
        var prefix = new string((partita.PrefissoTelefonoRiferimento ?? string.Empty).Where(char.IsDigit).ToArray());
        var number = new string((partita.TelefonoRiferimento ?? string.Empty).Where(char.IsDigit).ToArray());
        if (string.IsNullOrWhiteSpace(prefix) || string.IsNullOrWhiteSpace(number))
            return null;

        return $"{prefix}{number}";
    }

    string AbsoluteUrl(string relativeUrl)
    {
        var request = Context.Request;
        return $"{request.Scheme}://{request.Host}{relativeUrl}";
    }

    string JsString(string value) => System.Text.Json.JsonSerializer.Serialize(value);

    bool MatchesDuration(double actual, double expected) => Math.Abs(actual - expected) < 0.01;

    PricingEntry? ResolvePriceEntry(Partita partita)
    {
        var isKids = partita.Tipo?.Equals("kids", StringComparison.OrdinalIgnoreCase) ?? false;
        if (isKids)
        {
            if (partita.Torneo)
            {
                var tournamentEntry = pricingCatalog.GetEntry(PricingEntryCodes.KidsTournament);
                if (tournamentEntry != null && tournamentEntry.GetPrice(partita.Listino) > 0m)
                    return tournamentEntry;
            }

            if (MatchesDuration(partita.Durata, 1.0)) return pricingCatalog.GetEntry(PricingEntryCodes.Kids1Hour);
            if (MatchesDuration(partita.Durata, 1.5)) return pricingCatalog.GetEntry(PricingEntryCodes.Kids90Minutes);
            if (MatchesDuration(partita.Durata, 2.0)) return pricingCatalog.GetEntry(PricingEntryCodes.Kids2Hours);
            return null;
        }

        if (partita.Torneo)
            return pricingCatalog.GetEntry(partita.ColpiIllimitati
                ? PricingEntryCodes.AdultTournamentUnlimited
                : PricingEntryCodes.AdultTournamentStandard);

        if (partita.ColpiIllimitati)
        {
            if (MatchesDuration(partita.Durata, 1.0)) return pricingCatalog.GetEntry(PricingEntryCodes.AdultUnlimited1Hour);
            if (MatchesDuration(partita.Durata, 1.5)) return pricingCatalog.GetEntry(PricingEntryCodes.AdultUnlimited90Minutes);
        }

        if (MatchesDuration(partita.Durata, 1.0)) return pricingCatalog.GetEntry(PricingEntryCodes.AdultStandard1Hour);
        if (MatchesDuration(partita.Durata, 1.5)) return pricingCatalog.GetEntry(PricingEntryCodes.AdultStandard90Minutes);
        if (MatchesDuration(partita.Durata, 2.0)) return pricingCatalog.GetEntry(PricingEntryCodes.AdultStandard2Hours);
        return null;
    }

    decimal GetRabbitPrice(Partita partita)
    {
        if (!partita.Caccia)
            return 0m;

        var entry = pricingCatalog.GetEntry(partita.CacciaDoppia
            ? PricingEntryCodes.RabbitDouble
            : PricingEntryCodes.RabbitSingle);
        return entry?.GetPrice(partita.Listino) ?? 0m;
    }

    (decimal? PrezzoBase, decimal Caparra, decimal? Saldo, string Dettaglio) EstimateSaldo(Partita partita)
    {
        var entry = ResolvePriceEntry(partita);
        if (entry == null)
            return (null, partita.Caparra, null, "Listino non trovato");

        var prezzoUnitario = entry.GetPrice(partita.Listino);
        var prezzoExtra = GetRabbitPrice(partita);
        var prezzoBase = (prezzoUnitario * partita.NumeroPartecipanti) + prezzoExtra;
        var dettaglio = prezzoExtra > 0m
            ? $"{Money(prezzoUnitario)} x {partita.NumeroPartecipanti} + {Money(prezzoExtra)} extra"
            : $"{Money(prezzoUnitario)} x {partita.NumeroPartecipanti}";
        return (prezzoBase, partita.Caparra, prezzoBase - partita.Caparra, dettaglio);
    }

    string CalcButtonData(Partita partita, int iscritti)
    {
        var entry = ResolvePriceEntry(partita);
        var prezzoUnitario = entry?.GetPrice(partita.Listino) ?? 0m;
        var prezzoCaccia = GetRabbitPrice(partita);
        var tesseramentiDefault = iscritti > 0
            ? Math.Min(iscritti, partita.NumeroPartecipanti)
            : partita.NumeroPartecipanti;
        var payerPayload = (partita.Tesseramenti ?? new List<Tesseramento>())
            .OrderBy(t => t.Cognome)
            .ThenBy(t => t.Nome)
            .Select(t => new
            {
                id = t.Id,
                nome = t.Nome,
                cognome = t.Cognome
            })
            .ToList();
        var payerJson = System.Text.Json.JsonSerializer.Serialize(payerPayload);

        return string.Join(" ",
            $"data-id=\"{partita.Id}\"",
            $"data-unit-price=\"{prezzoUnitario.ToString("0.00", CultureInfo.InvariantCulture)}\"",
            $"data-caparra=\"{partita.Caparra.ToString("0.00", CultureInfo.InvariantCulture)}\"",
            $"data-rabbit-price=\"{prezzoCaccia.ToString("0.00", CultureInfo.InvariantCulture)}\"",
            $"data-participants=\"{partita.NumeroPartecipanti}\"",
            $"data-registered=\"{iscritti}\"",
            $"data-memberships=\"{Math.Max(0, tesseramentiDefault)}\"",
            $"data-membership-fee=\"{MembershipFee.ToString("0.00", CultureInfo.InvariantCulture)}\"",
            $"data-min-players=\"{MinimumBillablePlayers}\"",
            $"data-price-valid=\"{(entry != null && prezzoUnitario > 0m).ToString().ToLowerInvariant()}\"",
            $"data-detail=\"{System.Net.WebUtility.HtmlEncode(entry?.Label ?? "Listino non trovato")}\"",
            $"data-payers=\"{System.Net.WebUtility.HtmlEncode(payerJson)}\"");
    }
}

