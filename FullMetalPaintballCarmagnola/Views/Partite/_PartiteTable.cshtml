                    <td data-label="Iscritti">
                        <span class="iscritti-count @iscrittiClass">@iscritti</span>
                    </td>
                    <td data-label="Caparra">@Money(partita.Caparra)</td>

                    <td data-label="Listino">@GetListinoLabel(partita.Listino)</td>

                    <td data-label="Torneo" class="@(partita.Torneo ? "yes" : "no")">@((partita.Torneo) ? "SI" : "NO")</td>
                    <td data-label="Illimitati" class="@(partita.ColpiIllimitati ? "yes" : "no")">@((partita.ColpiIllimitati) ? "SI" : "NO")</td>
                    <td data-label="Caccia" class="@(partita.Caccia ? "yes" : "no")">
    @(partita.Caccia
        ? (partita.CacciaDoppia ? "SI x2" : "SI")
        : "NO")
</td>


                    <td data-label="Link">
