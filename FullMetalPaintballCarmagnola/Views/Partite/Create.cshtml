@model Full_Metal_Paintball_Carmagnola.Models.Partita
@using System.Text.Json

@{
    ViewData["Title"] = "Aggiungi Partita";
    var listinoAdultLabelsJson = JsonSerializer.Serialize(ViewBag.ListinoAdultLabels ?? new Dictionary<string, string>());
    var listinoKidsLabelsJson = JsonSerializer.Serialize(ViewBag.ListinoKidsLabels ?? new Dictionary<string, string>());
    var createPriceMapJson = JsonSerializer.Serialize(ViewBag.CreatePriceMap ?? new Dictionary<string, Dictionary<string, decimal?>>());
    var initialEmptyFields = ViewContext.ModelState.Count == 0;
}

<h2 class="mb-4">➕ Aggiungi Nuova Partita</h2>

<style>
    @@media (max-width: 768px) {
        #form-create-partita input.form-control,
        #form-create-partita select.form-control,
        #form-create-partita textarea.form-control {
            font-size: 16px;
        }
    }
</style>

<form asp-action="Create" method="post" id="form-create-partita" data-loading-message="Inserimento partita, attendere...">
    <div class="mb-3">
        <label asp-for="Data" class="form-label"></label>
        <input asp-for="Data" class="form-control" type="date" />
        <span asp-validation-for="Data" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Tipo" class="form-label">Tipo Partita</label>
        <select asp-for="Tipo" class="form-control" required>
            <option value="">-- Seleziona --</option>
            <option value="Adulti">Adulti</option>
            <option value="Kids">Kids</option>
        </select>

        <span asp-validation-for="Tipo" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Listino" class="form-label">Listino prezzi</label>
        <select asp-for="Listino" class="form-control" asp-items="ViewBag.ListinoOptions"></select>
        <span asp-validation-for="Listino" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="OraInizio" class="form-label">Ora Inizio</label>
        <input asp-for="OraInizio" class="form-control" type="time" value="@(initialEmptyFields ? "" : Model.OraInizio.ToString(@"hh\:mm"))" required />
        <span asp-validation-for="OraInizio" class="text-danger"></span>
    </div>

    <div class="row g-2 mb-3">
        <div class="col-md-5">
            <label asp-for="NomeRiferimento" class="form-label">Nome referente</label>
            <input asp-for="NomeRiferimento" class="form-control" placeholder="Nome e cognome" />
            <span asp-validation-for="NomeRiferimento" class="text-danger"></span>
        </div>
        <div class="col-4 col-md-2">
            <label asp-for="PrefissoTelefonoRiferimento" class="form-label">Prefisso</label>
            <input asp-for="PrefissoTelefonoRiferimento" class="form-control js-phone-prefix" placeholder="+39" />
            <span asp-validation-for="PrefissoTelefonoRiferimento" class="text-danger"></span>
        </div>
        <div class="col-8 col-md-5">
            <label asp-for="TelefonoRiferimento" class="form-label">Numero WhatsApp</label>
            <input asp-for="TelefonoRiferimento" class="form-control js-phone-number" placeholder="3461234567 oppure +39 346 1234567" />
            <span asp-validation-for="TelefonoRiferimento" class="text-danger"></span>
        </div>
    </div>

    <div class="mb-3">
        <label asp-for="Durata" class="form-label"></label>
        <select asp-for="Durata" class="form-control js-duration" required>
            <option value="">-- Seleziona --</option>
            <option value="1">1</option>
            <option value="1.5">1.5</option>
            <option value="2">2</option>
        </select>
        <span asp-validation-for="Durata" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="NumeroPartecipanti" class="form-label"></label>
        <input asp-for="NumeroPartecipanti" class="form-control" type="number" min="1" value="@(initialEmptyFields ? "" : Model.NumeroPartecipanti.ToString())" required />
        <span asp-validation-for="NumeroPartecipanti" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Caparra" class="form-label"></label>
        <input asp-for="Caparra" class="form-control js-deposit" type="number" step="0.01" min="0" value="@(initialEmptyFields ? "" : Model.Caparra.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture))" required />
        <span asp-validation-for="Caparra" class="text-danger"></span>
    </div>

    <div class="form-check mb-3">
        <input asp-for="CaparraConfermata" class="form-check-input" />
        <label asp-for="CaparraConfermata" class="form-check-label"></label>
    </div>

    <div class="form-group">
        <label asp-for="MetodoPagamentoCaparra" class="form-label">Metodo di Pagamento</label>
        <select asp-for="MetodoPagamentoCaparra" class="form-control">
            <option value="">-- Seleziona --</option>
            <option value="Satispay">Satispay</option>
            <option value="Bonifico Bancario">Bonifico Bancario</option>
        </select>
        <span asp-validation-for="MetodoPagamentoCaparra" class="text-danger"></span>
    </div>


    <div class="form-check mb-2">
        <input asp-for="Torneo" class="form-check-input" type="checkbox" />
        <label asp-for="Torneo" class="form-check-label"></label>
    </div>

    <div class="form-check mb-2">
        <input asp-for="ColpiIllimitati" class="form-check-input" type="checkbox" />
        <label asp-for="ColpiIllimitati" class="form-check-label"></label>
    </div>

    <div class="form-check mb-2">
        <input asp-for="Caccia" class="form-check-input" type="checkbox" id="chkCaccia" />
        <label asp-for="Caccia" class="form-check-label">🐰 Caccia al Coniglio</label>
    </div>

    <div class="form-check mb-4 ms-3" id="wrapCacciaX2" style="display:none;">
        <input asp-for="CacciaDoppia" class="form-check-input" type="checkbox" id="chkCacciaX2" />
        <label asp-for="CacciaDoppia" class="form-check-label">🐰 x2</label>
    </div>


    <button type="submit" class="btn btn-primary">Salva</button>
    <a asp-action="Index" class="btn btn-secondary">Annulla</a>
</form>

<script>
    (function () {
        const form = document.getElementById('form-create-partita');
        const tipoSelect = form ? form.querySelector('[name="Tipo"]') : null;
        const listinoSelect = form ? form.querySelector('[name="Listino"]') : null;
        const durationSelect = form ? form.querySelector('[name="Durata"]') : null;
        const unlimitedInput = form ? form.querySelector('[name="ColpiIllimitati"]') : null;
        const depositInput = form ? form.querySelector('.js-deposit') : null;
        const adultLabels = @Html.Raw(listinoAdultLabelsJson);
        const kidsLabels = @Html.Raw(listinoKidsLabelsJson);
        const priceMap = @Html.Raw(createPriceMapJson);

        function syncListinoLabels() {
            if (!tipoSelect || !listinoSelect) return;

            const labels = tipoSelect.value === 'Kids' ? kidsLabels : adultLabels;
            Array.from(listinoSelect.options).forEach(option => {
                if (labels[option.value]) {
                    option.textContent = labels[option.value];
                }
            });
        }

        function syncDepositFromPrice() {
            if (!tipoSelect || !listinoSelect || !durationSelect || !depositInput) return;

            const tipo = tipoSelect.value === 'Kids' ? 'Kids' : 'Adulti';
            const durata = durationSelect.value.replace(',', '.');
            const shotsMode = unlimitedInput?.checked ? 'unlimited' : 'standard';
            const pricesByListino = priceMap[listinoSelect.value] || {};
            const price = pricesByListino[`${tipo}|${shotsMode}|${durata}`];

            depositInput.value = price === null || price === undefined ? '' : Number(price).toFixed(2);
        }

        function syncUnlimitedAvailability() {
            if (!durationSelect || !unlimitedInput) return;

            const isAdultTwoHours = tipoSelect?.value !== 'Kids' && durationSelect.value.replace(',', '.') === '2';
            if (isAdultTwoHours) {
                unlimitedInput.checked = false;
            }

            unlimitedInput.disabled = isAdultTwoHours;
        }

        function normalizePhoneFields() {
            const prefixInput = form?.querySelector('.js-phone-prefix');
            const numberInput = form?.querySelector('.js-phone-number');
            if (!prefixInput || !numberInput) return;

            let rawNumber = (numberInput.value || '').trim().replace(/[\s\-./]/g, '');
            let rawPrefix = (prefixInput.value || '').trim();
            const knownPrefixes = ['420','421','423','386','385','387','381','380','351','352','353','354','355','356','357','358','359','212','213','216','218','376','377','378','379','590','591','592','593','594','595','596','597','598','599','39','33','34','41','44','49','31','32','43','45','46','47','48','36','40','30','1','7'];
            const digits = rawNumber.replace(/\D/g, '');
            const hasPrefix = rawPrefix.replace(/\D/g, '').length > 0;
            const looksLikeInternational = rawNumber.startsWith('+') || rawNumber.startsWith('00') || (!hasPrefix && digits.length > 10);
            if (looksLikeInternational) {
                const internationalDigits = rawNumber.startsWith('00') ? digits.replace(/^00/, '') : digits;
                const matchedPrefix = knownPrefixes
                    .sort((a, b) => b.length - a.length)
                    .find(prefix => internationalDigits.startsWith(prefix) && internationalDigits.length > prefix.length + 5);
                if (matchedPrefix) {
                    rawPrefix = `+${matchedPrefix}`;
                    rawNumber = internationalDigits.slice(matchedPrefix.length);
                }
            }

            const prefixDigits = rawPrefix.replace(/\D/g, '');
            prefixInput.value = prefixDigits ? `+${prefixDigits}` : '';
            numberInput.value = rawNumber.replace(/\D/g, '');
        }

        const phoneNumberInput = form?.querySelector('.js-phone-number');
        phoneNumberInput?.addEventListener('paste', function (event) {
            const pastedText = event.clipboardData?.getData('text');
            if (!pastedText) return;

            event.preventDefault();
            phoneNumberInput.value = pastedText;
            normalizePhoneFields();
        });
        phoneNumberInput?.addEventListener('blur', normalizePhoneFields);
        form?.querySelector('.js-phone-prefix')?.addEventListener('blur', normalizePhoneFields);
        form?.addEventListener('submit', normalizePhoneFields);

        if (tipoSelect) {
            tipoSelect.addEventListener('change', syncListinoLabels);
            syncListinoLabels();
        }

        [tipoSelect, listinoSelect, durationSelect, unlimitedInput].forEach(element => {
            element?.addEventListener('change', () => {
                syncUnlimitedAvailability();
                syncDepositFromPrice();
            });
        });
        syncUnlimitedAvailability();

        // ✅ toggle caccia x2
        const chkCaccia = document.getElementById('chkCaccia');
        const wrapX2 = document.getElementById('wrapCacciaX2');
        const chkX2 = document.getElementById('chkCacciaX2');

        function syncX2() {
            const on = chkCaccia && chkCaccia.checked;
            if (wrapX2) wrapX2.style.display = on ? 'block' : 'none';
            if (!on && chkX2) chkX2.checked = false;
        }
        if (chkCaccia) {
            chkCaccia.addEventListener('change', syncX2);
            syncX2();
        }
    })();
</script>
